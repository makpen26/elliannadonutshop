{
  "name": "bakery-spa",
  "version": "1.0.0",
  "description": "Wildflour Bakery SPA with Sveltia CMS content management",
  "private": true,
  "scripts": {
    "build:content": "node scripts/build-content.js",
    "build": "node scripts/build-content.js && webpack --mode production",
    "dev": "node scripts/build-content.js && webpack serve --mode development",
    "watch": "node scripts/build-content.js && webpack --mode development --watch"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  }
}
